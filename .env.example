################################################################################
# DreamFi Massive Upgrade — Environment Configuration
# Last Updated: Phase 1-5 (Complete Platform)
################################################################################

# ─── CORE INFRASTRUCTURE ───

# Database (Primary)
DATABASE_URL=postgresql://dreamfi:password@localhost:5432/dreamfi_dev
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT_SECONDS=30

# Environment & Logging
ENVIRONMENT=development
LOG_LEVEL=INFO
SERVICE_PORT=3000

# ─── ANTHROPIC (LLM for Knowledge Hub + Generators) ───
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── TRACK A: CORE PLATFORM HARDENING ───
# Contract Loading & Validation
SKILL_CONTRACTS_PATH=./evals
CONTRACT_VALIDATION_STRICT=true

# Schema & Migrations
DB_MIGRATIONS_PATH=./services/knowledge-hub/db/migrations
DB_SEEDS_PATH=./services/knowledge-hub/db/seeds
DB_MIGRATION_TIMEOUT_SECONDS=60

# ─── TRACK B: CONNECTOR MATURITY ───

# Jira Connector
JIRA_URL=https://dreamfi.atlassian.net
JIRA_EMAIL=paul@dreamfi.com
JIRA_API_TOKEN=
JIRA_FRESHNESS_HALF_LIFE_DAYS=7
JIRA_SYNC_PAGE_SIZE=100
JIRA_WEBHOOK_SECRET=

# Confluence Connector
CONFLUENCE_URL=https://dreamfi.atlassian.net/wiki
CONFLUENCE_EMAIL=paul@dreamfi.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_FRESHNESS_HALF_LIFE_DAYS=14
CONFLUENCE_SYNC_PAGE_SIZE=50
CONFLUENCE_WEBHOOK_SECRET=

# Dragonboat (Planning)
DRAGONBOAT_API_URL=https://api.dragonboat.io/v1
DRAGONBOAT_API_KEY=
DRAGONBOAT_FRESHNESS_HALF_LIFE_DAYS=7
DRAGONBOAT_SYNC_PAGE_SIZE=100

# Metabase (Analytics)
METABASE_URL=https://metabase.internal.dreamfi.com
METABASE_USERNAME=
METABASE_PASSWORD=
METABASE_FRESHNESS_HALF_LIFE_DAYS=1

# PostHog (Product Analytics)
POSTHOG_API_KEY=phx_...
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_FRESHNESS_HALF_LIFE_HOURS=6

# Google Analytics
GA_PROPERTY_ID=
GA_CREDENTIALS_PATH=./credentials/ga-service-account.json
GA_FRESHNESS_HALF_LIFE_HOURS=24

# Lucidchart (Diagrams)
LUCIDCHART_API_URL=https://api.lucidchart.com/v1
LUCIDCHART_API_KEY=

# Klaviyo (Email/CRM)
KLAVIYO_API_KEY=pk_...
KLAVIYO_FRESHNESS_HALF_LIFE_HOURS=12

# Sardine (Fraud Monitoring)
SARDINE_API_URL=https://api.sardine.ai/v1
SARDINE_CLIENT_ID=
SARDINE_SECRET_KEY=
SARDINE_FRESHNESS_HALF_LIFE_HOURS=1

# Socure (Identity Verification)
SOCURE_API_URL=https://api.socure.com/v3
SOCURE_API_KEY=
SOCURE_FRESHNESS_HALF_LIFE_HOURS=2

# Ledger NetXD (Ledger Integration)
NETXD_API_URL=https://api.netxd.com/v1
NETXD_API_KEY=
NETXD_CLIENT_ID=
NETXD_FRESHNESS_HALF_LIFE_HOURS=4

# Connector Framework Settings
CONNECTOR_RETRY_MAX_ATTEMPTS=3
CONNECTOR_RETRY_BACKOFF_MULTIPLIER=2
CONNECTOR_SYNC_TIMEOUT_SECONDS=300
CONNECTOR_DEAD_LETTER_PATH=./logs/dead-letter

# Webhook Support (Track B.3)
WEBHOOK_PORT=3001
WEBHOOK_SIGNATURE_ALGORITHM=hmac-sha256
WEBHOOK_EVENT_DEDUPE_WINDOW_SECONDS=600

# ─── TRACK C: KNOWLEDGE HUB INTELLIGENCE ───

# Retrieval Configuration
RETRIEVAL_MAX_RESULTS=10
RETRIEVAL_FRESHNESS_WEIGHT=0.3
RETRIEVAL_CITATION_WEIGHT=0.4
RETRIEVAL_RELEVANCE_WEIGHT=0.3

# Entity Resolution
ENTITY_RESOLUTION_CONFIDENCE_THRESHOLD=0.85
ENTITY_ALIAS_PATH=./data/entity-aliases.json

# Citation & Confidence
CITATION_REQUIRED_FOR_ANSWERS=true
CITATION_MIN_COUNT_FOR_HIGH_CONFIDENCE=3
CONFIDENCE_THRESHOLD_FOR_PUBLISH=0.7
CONFIDENCE_STALE_SOURCE_PENALTY=0.15
CONFIDENCE_CONTRADICTION_PENALTY=0.2
CONFIDENCE_LOW_CITATION_PENALTY=0.25

# ─── TRACK D: SKILL ENGINE & EVAL RIGOR ───

# Tier 1 Skills (Generation)
GENERATION_MODEL=claude-3-5-sonnet-20241022
GENERATION_MAX_TOKENS=2000
GENERATION_TEMPERATURE=0.7

# Tier 1 Skills: agent_system_prompt
AGENT_SYSTEM_PROMPT_MAX_WORDS=80
AGENT_SYSTEM_PROMPT_HARD_GATES=true

# Tier 1 Skills: support_agent
SUPPORT_AGENT_MAX_WORDS=120
SUPPORT_AGENT_MAX_MESSAGES=3
SUPPORT_AGENT_HARD_GATES=true

# Tier 1 Skills: meeting_summary
MEETING_SUMMARY_MAX_WORDS=300
MEETING_SUMMARY_HARD_GATES=true

# Tier 2/3 Skills Configuration
TIER2_SKILLS=cold_email,landing_page_copy,newsletter_headline,product_description,resume_bullet
TIER3_SKILLS=short_form_script

# Eval Runner Configuration
EVAL_RUNNER_IMMUTABILITY_CHECK=true
EVAL_RUNNER_CHECKSUM_VALIDATION=true
EVAL_TIMEOUT_SECONDS=120
EVAL_ROUND_SIZE=10

# Results Analysis
RESULTS_ANALYZER_AUTO_GENERATE=true
RESULTS_ANALYZER_MIN_ROUNDS_FOR_PATTERNS=3

# Prompt Lifecycle
PROMPT_IMPROVEMENT_THRESHOLD_PERCENT=2.0
PROMPT_MAX_VERSIONS_RETAINED=20
PROMPT_AUTO_ROLLBACK_ON_REGRESSION=true

# ─── TRACK E: PUBLISH & WORKFLOW CONTROLS ───

# Publish Guards
PUBLISH_HARD_GATE_REQUIRED=true
PUBLISH_CONFIDENCE_MIN=0.7
PUBLISH_FRESHNESS_MIN=0.3
PUBLISH_CITATIONS_REQUIRED=true

# Artifact Versioning
ARTIFACT_SNAPSHOT_RETENTION_DAYS=90
ARTIFACT_AUTO_VERSION_SCHEMA=true

# Manual Review Workflow
REVIEW_QUEUE_AUTO_ROUTE_CONFIDENCE_RANGE=[0.6, 0.75]
REVIEW_QUEUE_APPROVAL_TIMEOUT_HOURS=24
REVIEW_AUTO_ESCALATE_ON_OVERRIDE=true

# ─── TRACK F: PLANNING & REPORTING TRUST ───

# Planning Sync Configuration
PLANNING_HIERARCHY_MAX_DEPTH=5
PLANNING_STATUS_MAPPING_FILE=./config/status-mappings.json
PLANNING_REQUIRED_FIELDS=owner,deadline,status
PLANNING_FRESHNESS_SLA_JIRA_HOURS=24
PLANNING_FRESHNESS_SLA_DRAGONBOAT_HOURS=168

# Report Generation
REPORT_AUTO_GENERATE_SKILL=generate_report_summary
REPORT_INCLUDE_TRUST_FLAGS=true
REPORT_ESCALATION_CONFIDENCE_THRESHOLD=0.5

# ─── TRACK G: METRICS & INTERPRETATION TRUST ───

# Metric Catalog
METRIC_CATALOG_FILE=./config/metric-catalog.json
METRIC_OWNER_REQUIRED=true
METRIC_SOURCE_OF_TRUTH_REQUIRED=true

# Cross-Source Normalization
IDENTITY_NORMALIZATION_CONFIG=./config/identity-normalization.json
FUNNEL_STAGE_NORMALIZATION_CONFIG=./config/funnel-normalization.json
FRAUD_DECISION_NORMALIZATION_CONFIG=./config/fraud-normalization.json

# Metric Trust Scoring
METRIC_DATA_TRUST_WEIGHT=0.6
METRIC_INTERPRETATION_TRUST_WEIGHT=0.4
METRIC_DISCREPANCY_PENALTY=0.2
METRIC_STALE_PENALTY_PER_DAY=0.01

# Anomaly Detection
ANOMALY_DETECTION_ENABLED=true
ANOMALY_STDDEV_THRESHOLD=2.5
ANOMALY_MIN_HISTORICAL_POINTS=10

# ─── TRACK H: UI SUPPORT & ARTIFACT QUALITY ───

# Fintech Minimalism Rules
UI_RULE_ENGINE_ENABLED=true
UI_MIN_SPACING_REM=0.5
UI_MAX_SPACING_REM=4.0
UI_RESPONSIVE_BREAKPOINTS=320,768,1200
UI_DARK_MODE_REQUIRED=true

# Export Readiness
UI_HARD_CODED_LAYOUT_BLOCKED=true
UI_SEMANTIC_HTML_REQUIRED=true
UI_COPY_SKILL_EVAL_REQUIRED=true

# ─── TRACK I: GOVERNANCE, SECURITY, REPRODUCIBILITY ───

# Data Handling & Redaction
SECURITY_REDACT_PII=true
SECURITY_REDACT_FRAUD_DECISIONS=true
SECURITY_REDACT_LEDGER_DATA=true
SECURITY_REDACTION_PATTERNS_FILE=./config/redaction-patterns.json

# RACI & Approval Workflow
GOVERNANCE_PROMPT_PROMOTION_REQUIRES_APPROVAL=true
GOVERNANCE_PUBLISH_REQUIRES_APPROVAL=true
GOVERNANCE_PROMPT_ROLLBACK_REQUIRES_REASON=true

# Prompt Approval
PROMPT_APPROVAL_REVIEWERS_FILE=./config/prompt-reviewers.json
PROMPT_TIER1_REQUIRES_APPROVAL=true
PROMPT_APPROVAL_TIMEOUT_HOURS=48

# Identity Resolution
IDENTITY_RESOLUTION_CONFLICT_STRATEGY=conservative
IDENTITY_RESOLUTION_AUDIT_LOG=./logs/identity-audit.log
IDENTITY_RESOLUTION_UNRESOLVED_ESCALATION=true

# ─── TRACK J: DEVELOPER VELOCITY & INTERNAL UX ───

# Internal Operator Console
INTERNAL_HUB_PORT=3002
INTERNAL_HUB_AUTH_REQUIRED=true
INTERNAL_HUB_ENABLE_EVAL_RUN_UI=true
INTERNAL_HUB_ENABLE_CONNECTOR_HEALTH=true
INTERNAL_HUB_ENABLE_PROMPT_DIFF=true

# Bootstrap & Local Development
BOOTSTRAP_INCLUDE_MOCK_DATA=true
BOOTSTRAP_INCLUDE_FIXTURE_CONNECTORS=true
BOOTSTRAP_AUTO_RUN_MIGRATIONS=true
BOOTSTRAP_AUTO_SEED_DATA=true

# Observability & Monitoring
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_STALE_CONNECTOR_ALERT_HOURS=24
OBSERVABILITY_EVAL_REGRESSION_ALERT_THRESHOLD=0.02
OBSERVABILITY_PUBLISH_FAILURE_ALERT_THRESHOLD=0.1

# Developer Logs
DEV_LOG_SQL_QUERIES=false
DEV_LOG_LLM_REQUESTS=false
DEV_LOG_CONNECTOR_SYNC=true

# ─── TESTING & CI/CD ───

# Test Database
TEST_DATABASE_URL=postgresql://dreamfi_test:password@localhost:5432/dreamfi_test
TEST_DATABASE_AUTO_RESET=true
TEST_DATABASE_ISOLATION=true

# Pytest Configuration
PYTEST_MARKERS=unit,integration,e2e,critical,requires_real_api,slow
PYTEST_TIMEOUT_SECONDS=300

# CI/CD
CI_ENFORCE_CONTRACT_DRIFT_CHECK=true
CI_ENFORCE_100_PERCENT_TIER1_TESTS=true
CI_ENFORCE_ALL_HARD_GATES=true
CI_BLOCK_MERGE_ON_TEST_FAILURE=true

# ─── PHASE GATES ───
# These are checked by CI to enforce build order

PHASE1_MIN_TEST_PASS_RATE=1.0
PHASE1_REQUIRED_TESTS=contract_alignment,migrations,schema_sync,health_endpoints

PHASE2_MIN_TEST_PASS_RATE=1.0
PHASE2_REQUIRED_TESTS=connector_sync,freshness_scoring,tier1_generation,eval_runner

PHASE3_MIN_TEST_PASS_RATE=1.0
PHASE3_REQUIRED_TESTS=planning_hierarchy,status_mapping,report_generation

PHASE4_MIN_TEST_PASS_RATE=1.0
PHASE4_REQUIRED_TESTS=metric_normalization,metric_trust,metric_narrative

PHASE5_MIN_TEST_PASS_RATE=1.0
PHASE5_REQUIRED_TESTS=ui_export_readiness,artifact_versioning,publish_guard

# ─── OPTIONAL: FEATURE FLAGS ───
FEATURE_WEBHOOK_SYNC=true
FEATURE_AUTO_ROLLBACK=true
FEATURE_MANUAL_REVIEW_QUEUE=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_OPERATOR_CONSOLE=true
