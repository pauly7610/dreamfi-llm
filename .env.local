# .env.local - Local development configuration
# Copy from .env.example and fill in your local values
# DO NOT COMMIT THIS FILE

# Database
DATABASE_URL=postgresql://dreamfi_dev:local_password@localhost:5432/dreamfi_dev
POSTGRES_USER=dreamfi_dev
POSTGRES_PASSWORD=local_password
POSTGRES_DB=dreamfi_dev

# Connectors - Fill these from your infrastructure
# Jira
JIRA_HOST=https://dreamfi.atlassian.net
JIRA_USER_EMAIL=api@dreamfi.com
JIRA_API_TOKEN=your_jira_api_token_here

# Dragonboat
DRAGONBOAT_API_URL=https://api.dragonboat.app
DRAGONBOAT_API_KEY=your_dragonboat_key_here

# Confluence
CONFLUENCE_HOST=https://dreamfi.atlassian.net
CONFLUENCE_USER_EMAIL=api@dreamfi.com
CONFLUENCE_API_TOKEN=your_confluence_token_here

# Metabase
METABASE_URL=http://localhost:3000
METABASE_USER=your_metabase_user
METABASE_PASSWORD=your_metabase_password

# PostHog
POSTHOG_API_KEY=your_posthog_key_here
POSTHOG_HOST=https://us.posthog.com

# Google Analytics
GOOGLE_ANALYTICS_VIEW_ID=your_ga_view_id
GOOGLE_ANALYTICS_CREDENTIALS={"type":"service_account",...}

# Klaviyo
KLAVIYO_API_KEY=your_klaviyo_key_here

# NetXD / Ledger
LEDGER_NETXD_API_KEY=your_netxd_key_here

# Sardine
SARDINE_API_KEY=your_sardine_key_here

# Socure
SOCURE_API_KEY=your_socure_key_here

# Lucidchart
LUCIDCHART_API_TOKEN=your_lucidchart_token_here

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4-turbo

# Storage
OBJECT_STORE_PATH=./data/raw-payloads
RESULTS_LOG_PATH=./data/eval-results

# Feature Flags
FEATURE_CONNECTOR_JIRA_ENABLED=true
FEATURE_CONNECTOR_DRAGONBOAT_ENABLED=true
FEATURE_CONNECTOR_CONFLUENCE_ENABLED=true
FEATURE_CONNECTOR_LUCIDCHART_ENABLED=true
FEATURE_CONNECTOR_METABASE_ENABLED=true
FEATURE_CONNECTOR_POSTHOG_ENABLED=true
FEATURE_CONNECTOR_GA_ENABLED=true
FEATURE_CONNECTOR_KLAVIYO_ENABLED=true
FEATURE_CONNECTOR_NETXD_ENABLED=true
FEATURE_CONNECTOR_SARDINE_ENABLED=true
FEATURE_CONNECTOR_SOCURE_ENABLED=true

SYNC_INTERVAL_SECONDS=3600

# Eval Configuration
EVAL_DRY_RUN=true
EVAL_BLOCK_ON_REGRESSION=false

# Publishing
PUBLISHER_CONFIRM_BEFORE_SEND=true

# Observability
LOG_LEVEL=debug
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Redis
REDIS_URL=redis://localhost:6379

# Environment
ENV=development
DEBUG=true
